# segredos
.env

# dados brutos e traduzidos (pesados, e alguns PDFs da ONU podem ter
# restrições de redistribuição; mantenha o script de coleta, não os dados)
data/*
!data/.gitkeep

# saídas geradas (tabelas e figuras são reproduzíveis a partir do script)
output/*
!output/.gitkeep

# Python
__pycache__/
*.pyc
.ipynb_checkpoints/
venv/
.venv/
